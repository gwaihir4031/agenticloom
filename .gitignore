node_modules/
dist/
loom/runs/
coverage/

# Smoke-test tree (smoke_test/) is tracked, EXCEPT per-run workspaces
# created by `cd smoke_test && loom run ...`. Those are auto-regenerated
# and never load-bearing for future runs.
smoke_test/loom/runs/

# Same for the getting-started starter pack: the pipelines are tracked,
# but per-run workspaces (created when a reader runs a chapter) are not.
examples/getting-started/loom/runs/
